@model IEnumerable<QuatTran.Application.DTOs.OrderDto>
@{
    ViewData["Title"] = "Đơn hàng của bạn";
}

<h2>Đơn hàng của bạn</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">Bạn chưa có đơn hàng nào.</div>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Mã đơn</th>
                <th>Ngày đặt</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.OrderId</td>
                    <td>@order.OrderDate.ToString("dd/MM/yyyy")</td>
                    <td>@order.TotalAmount.ToString("N0") VNĐ</td>
                    <td>@order.ShippingStatus</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-primary">Xem chi tiết</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
