@model IEnumerable<QuatTran.Application.DTOs.ProductDto>
@{
    ViewData["Title"] = "Trang chủ";
    var categories = ViewBag.Categories as IEnumerable<QuatTran.Application.DTOs.CategoryDto>;
    var keyword = ViewBag.Keyword as string;
    var selectedCategory = ViewBag.SelectedCategory as int?;
}
<div id="carouselExample" class="carousel slide mb-4" data-bs-ride="carousel">
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="/uploads/Banner-quat-tran.png" class="d-block w-100" style="height:300px;object-fit:cover;">
        </div>
        <div class="carousel-item">
            <img src="/uploads/banner2.jpg" class="d-block w-100" style="height:300px;object-fit:cover;">
        </div>
        <div class="carousel-item">
        <img src="/uploads/banner3.jpg" class="d-block w-100" style="height:300px;object-fit:cover;">
    </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<div class="container mt-4">
    <h2 class="mb-4">Sản phẩm nổi bật</h2>

    <form method="get" class="row g-2 mb-4">
        <div class="col-md-3">
            <select name="categoryId" class="form-select">
                <option value="">-- Tất cả danh mục --</option>
                @foreach (var cat in categories)
                {
                    <option value="@cat.CategoryId" selected="@(selectedCategory == cat.CategoryId)">
                        @cat.Name
                    </option>
                }
            </select>
        </div>
        <div class="col-md-5">
            <input name="keyword" value="@keyword" class="form-control" placeholder="Tìm kiếm sản phẩm..." />
        </div>
        <div class="col-md-2">
            <button class="btn btn-primary w-100">Tìm kiếm</button>
        </div>
        <h2></h2>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Không tìm thấy sản phẩm nào.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-4 g-4">
            @foreach (var p in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <img src="@p.ImageUrl" class="card-img-top" style="height:200px;object-fit:contain;" />
                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title">@p.ProductName</h6>
                            <p class="card-text text-danger fw-bold mb-2">@p.Price.ToString("N0") VNĐ</p>
                            <a asp-controller="Product" asp-action="Details" asp-route-id="@p.ProductId" class="btn btn-outline-primary mt-auto">
                                Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
<footer class="bg-light py-4 mt-5 border-top">
    <div class="container">
        <div class="row">
            <div class="col-md-4 mb-3">
                <img src="/uploads/logo.png" alt="Logo Công Ty" style="height:40px;">
                <p class="mt-2">CÔNG TY TNHH QUẠT TRẦN VIỆT NAM</p>
                <ul class="list-unstyled small">
                    <li><strong>Địa chỉ:</strong> Số 10 Đường ABC, Quận 1, TP.HCM</li>
                    <li><strong>MST:</strong> 0123456789 - Ngày cấp: 01/01/2024</li>
                    <li><strong>Nơi cấp:</strong> Sở KH&ĐT TP.HCM</li>
                    <li><strong>Số TK:</strong> 123456789 tại BIDV CN Sài Gòn</li>
                    <li><strong>Điện thoại:</strong> 0909 123 456</li>
                </ul>
                <div class="d-flex gap-2 mt-2">
                    <a href="#" class="text-dark"><i class="fab fa-facebook fa-lg"></i></a>
                    <a href="#" class="text-dark"><i class="fab fa-youtube fa-lg"></i></a>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <h6>Showroom TP.HCM</h6>
                <ul class="list-unstyled small">
                    <li><i class="fas fa-map-marker-alt"></i> 123 Đường X, Quận 3, TP.HCM</li>
                    <li><i class="fas fa-phone"></i> 0901 234 567</li>
                </ul>
                <h6>Chính sách</h6>
                <ul class="list-unstyled small">
                    <li><a href="#">Chính sách bảo mật</a></li>
