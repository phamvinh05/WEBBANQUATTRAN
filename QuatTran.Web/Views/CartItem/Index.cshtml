@model IEnumerable<QuatTran.Application.DTOs.CartItemDto>

@{
    ViewData["Title"] = "Giỏ hàng";
}

<h2 class="mt-4 mb-3">🛒 Giỏ hàng của bạn</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">Giỏ hàng của bạn đang trống.</div>
}
else
{
    <table class="table table-bordered">
        <thead class="table-light">
            <tr>
                <th></th>
                <th>Sản phẩm</th>
                <th>Giá</th>
                <th>Số lượng</th>
                <th>Tổng</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="width:80px;">
                        <img src="@item.ProductImageUrl" class="img-thumbnail" style="width:70px;" />
                    </td>
                    <td>@item.ProductName</td>
                    <td>@item.ProductPrice.ToString("N0") VNĐ</td>
                    <td>
                        <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                            <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control form-control-sm w-50" />
                            <button type="submit" class="btn btn-sm btn-primary ms-2">Cập nhật</button>
                        </form>
                    </td>
                    <td>@(item.ProductPrice * item.Quantity).ToString("N0") VNĐ</td>
                    <td>
                        <form asp-action="Remove" method="post" class="d-inline">
                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                            <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                        </form>
                        <form asp-controller="Order" asp-action="Create" method="post" class="d-inline">
                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                            <button type="submit" class="btn btn-sm btn-success">Thanh toán</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="alert alert-info mt-3">
        <strong>Tổng cộng:</strong>
        @Model.Sum(x => x.ProductPrice * x.Quantity).ToString("N0") VNĐ
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success mt-2">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mt-2">@TempData["Error"]</div>
}
