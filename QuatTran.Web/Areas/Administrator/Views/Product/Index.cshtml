@model IEnumerable<QuatTran.Application.DTOs.ProductDto>

<table class="table table-bordered">
    <p>
        <a asp-area="Administrator" asp-controller="Product" asp-action="Create" class="btn btn-primary">
            Thêm sản phẩm
        </a>
    </p>

    <thead>
        <tr>
            <th>Ảnh chính</th>
            <th>Tên sản phẩm</th>
            <th>Mô tả</th>
            <th>Giá</th>
            <th>Ảnh phụ</th>
            <th>Chỉnh sửa</th>
        </tr>
    </thead>
    <tbody>
        
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" style="width:80px;" />
                    }
                </td>
                <td>@item.ProductName</td>
                <td>@item.Description</td>
                <td>@item.Price.ToString("N0") đ</td>
                <td>
                    @if (item.AdditionalImages != null && item.AdditionalImages.Any())
                    {
                        foreach (var img in item.AdditionalImages)
                        {
                            <img src="@img.ImageUrl" style="width:60px; margin:2px;" />
                        }
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.ProductId" class="btn btn-sm btn-danger">Xóa</a>
                    <a asp-action="UploadImages" asp-route-productId="@item.ProductId" class="btn btn-sm btn-info">Ảnh phụ</a>
                </td>
            </tr>
        }
    </tbody>
</table>
