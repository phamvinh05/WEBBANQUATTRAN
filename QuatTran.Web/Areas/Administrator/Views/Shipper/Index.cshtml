@model IEnumerable<QuatTran.Application.DTOs.ShipperDto>
@{
    ViewData["Title"] = "Danh sách Shipper";
}
<h2>Danh sách Shipper</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Thêm Shipper</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Tên công ty</th>
            <th>Số điện thoại</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.CompanyName</td>
                <td>@s.Phone</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@s.ShipperId" class="btn btn-sm btn-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@s.ShipperId" class="btn btn-sm btn-danger">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
